# Project base settings
ENV=production
LOG_LEVEL=INFO
APP_CONFIG_FILEPATH=config.yaml
# Generate a unique value before starting production, for example:
# openssl rand -hex 32
API_KEY_SECRET=replace-with-strong-random-secret
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
SESSIONS_STREAM_INTERVAL_SECONDS=15
MARKETPLACE_MAX_UPLOAD_BYTES=26214400

# Database settings for docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manus
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@manus-postgres:5432/manus
SQLALCHEMY_ECHO=false
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_RECYCLE_SECONDS=1800

# Redis settings for docker-compose
REDIS_HOST=manus-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DISPATCH_STREAM_MAXLEN=10000
REDIS_TASK_INPUT_STREAM_MAXLEN=10000
REDIS_TASK_OUTPUT_STREAM_MAXLEN=50000
TASK_DISPATCH_MAX_RETRIES=3
WORKER_MAX_CONCURRENT_TASKS=4

# Memory / embeddings
MEMORY_RECALL_LIMIT=20
MEMORY_AUTO_EXTRACT_ENABLED=true
MEMORY_VECTOR_ENABLED=false
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Tencent COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=https
COS_BUCKET=
COS_DOMAIN=

# Sandbox
SANDBOX_ADDRESS=
SANDBOX_IMAGE=manus-sandbox
SANDBOX_NAME_PREFIX=manus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=manus-network
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=localhost,127.0.0.1,manus-api,manus-ui,manus-redis,manus-postgres
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPU_LIMIT=2
SANDBOX_PIDS_LIMIT=512
SANDBOX_POOL_ENABLED=true
SANDBOX_POOL_SIZE=2
SANDBOX_IDLE_TIMEOUT_MINUTES=30
SANDBOX_WARMUP_RETRY_INTERVAL_SECONDS=0.5

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=my-manus-api
OTEL_EXPORTER_ENDPOINT=
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Secrets / config governance
VAULT_ADDR=
VAULT_TOKEN=
USE_DB_APP_CONFIG=false

# Nginx
NGINX_PORT=8088

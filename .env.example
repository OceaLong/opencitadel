# =============================================================================
# Bootstrap & secrets (.env) — behavior config in api/config.yaml
# 启动引导与密钥（.env）— 行为类配置见 api/config.yaml
# =============================================================================

# ==================== Deployment mode / 部署模式（二选一） ====================
# cloud (default): Tencent COS + external LLM keys
#   -> leave COMPOSE_PROFILES empty + STORAGE_PROVIDER=cos + fill COS_*
# cloud（默认）: 腾讯云 COS + 外部 LLM Key
#   -> COMPOSE_PROFILES 留空 + STORAGE_PROVIDER=cos + 填写 COS_*
# local: bundled MinIO + host Ollama
#   -> COMPOSE_PROFILES=local + STORAGE_PROVIDER=minio
# local（全本地）: 内置 MinIO + 宿主机 Ollama
#   -> COMPOSE_PROFILES=local + STORAGE_PROVIDER=minio
COMPOSE_PROFILES=
STORAGE_PROVIDER=cos

# ---------- Required minimum / 必填最小集 ----------

ENV=production
LOG_LEVEL=INFO

# Example placeholders (>=32 chars); override in production: openssl rand -hex 32
# 开箱即用示例（≥32 字符）；生产建议自行覆盖: openssl rand -hex 32
API_KEY_SECRET=REDACTED_API_KEY_SECRET
JWT_SECRET=change-me-with-openssl-rand-hex-32
SESSION_SECRET=change-me-with-openssl-rand-hex-32
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
COOKIE_DOMAIN=
COOKIE_SECURE=true
FRONTEND_BASE_URL=https://example.com
OAUTH_REDIRECT_BASE=https://example.com/api/auth/oauth
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# Database (Compose default host: opencitadel-postgres)
# 数据库（Docker Compose 默认主机名 opencitadel-postgres）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opencitadel
POSTGRES_HOST=opencitadel-postgres

# Redis (leave REDIS_PASSWORD empty when no password)
# Redis（未设置密码时 REDIS_PASSWORD 留空）
REDIS_HOST=opencitadel-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Tencent COS (cloud mode; optional in local mode)
# 腾讯云 COS（cloud 模式填写；local 模式可留空）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_DOMAIN=

# MinIO (local mode; optional in cloud mode)
# MinIO（local 模式填写；cloud 模式可留空）
MINIO_ENDPOINT=opencitadel-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=opencitadel
MINIO_SECURE=false
# Optional public URL for LLM image fetch; empty falls back to base64 inline
# 可选：需要 LLM 直接抓取图片 URL 时填写公网/局域网可达地址；留空则自动回退 base64 内联
MINIO_PUBLIC_ENDPOINT=

# Nginx host ports (docker-compose only)
# Nginx 对外端口（仅 docker-compose）
NGINX_PORT=8088
NGINX_HTTPS_PORT=443

# Domain & HTTPS (prepare certs before enabling; default path /etc/letsencrypt/live/${OPENCITADEL_DOMAIN}/)
# 域名与 HTTPS（启用 HTTPS 前需自行准备证书，默认路径 /etc/letsencrypt/live/${OPENCITADEL_DOMAIN}/）
OPENCITADEL_DOMAIN=
HTTPS_ENABLED=false

# ---------- Optional feature keys / 按功能启用的密钥（可选） ----------

# Vector memory: set memory.vector_enabled: true in api/config.yaml first
# 向量记忆：在 api/config.yaml 设置 memory.vector_enabled: true 后填写
EMBEDDING_API_KEY=

# Local models (recommended for local mode)
# 本地模型（local 模式推荐）
# Add models in UI Settings; provider ollama or openai-compatible (vLLM, etc.)
# base_url e.g. http://host.docker.internal:11434/v1 for host Ollama from containers

# Enterprise KB connectors / 企业文档知识库连接器（可选）
CONFLUENCE_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Langfuse: set observability.langfuse_enabled: true in api/config.yaml first
# Langfuse：在 api/config.yaml 设置 observability.langfuse_enabled: true 后填写
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Google/GitHub SSO (leave empty to disable)
# Google/GitHub SSO（可选；保持空值则不启用对应登录入口）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Advanced (usually unchanged) / 高级可选项（通常无需修改） ----------

# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@opencitadel-postgres:5432/opencitadel
# APP_CONFIG_FILEPATH=config.yaml
# SQLALCHEMY_ECHO=false
# POSTGRES_POOL_SIZE=10
# POSTGRES_MAX_OVERFLOW=20
# POSTGRES_POOL_RECYCLE_SECONDS=1800
# COS_SCHEME=https
# Persist runtime AppConfig to DB (recommended for production)
# 将运行时 AppConfig 持久化到数据库（生产环境推荐 true）
# USE_DB_APP_CONFIG=true

# Demo profile (OpsConsole ticket backend for Web Operator e2e)
# docker compose --profile local --profile demo up
# OPS_CONSOLE_PORT=9099
# Docker 构建期镜像源（覆盖 docker-compose build args 默认值）
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# PIP_TRUSTED_HOST=mirrors.aliyun.com
# UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# UV_VERSION=0.11.19
# NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

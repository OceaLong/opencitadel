# =============================================================================
# 启动引导与密钥（.env）— 行为类配置见 api/config.yaml
# =============================================================================

# 项目基础
ENV=production
LOG_LEVEL=INFO
APP_CONFIG_FILEPATH=config.yaml
# 生产环境必须设置强密钥: openssl rand -hex 32
API_KEY_SECRET=replace-with-strong-random-secret

# 数据库连接（引导层，启动前必须可用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manus
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@manus-postgres:5432/manus
SQLALCHEMY_ECHO=false
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_RECYCLE_SECONDS=1800

# Redis 连接
REDIS_HOST=manus-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 腾讯云 COS（密钥与桶）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=https
COS_BUCKET=
COS_DOMAIN=

# 嵌入 / 可观测性密钥（行为开关见 config.yaml memory / observability）
EMBEDDING_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Vault（可选）
VAULT_ADDR=
VAULT_TOKEN=

# Nginx（仅 docker-compose）
NGINX_PORT=8088

# =============================================================================
# 启动引导与密钥（.env）— 行为类配置见 api/config.yaml
# =============================================================================

# ---------- 必填最小集 ----------

ENV=production
LOG_LEVEL=INFO

# 开箱即用示例（≥32 字符）；生产建议自行覆盖: openssl rand -hex 32
API_KEY_SECRET=REDACTED_API_KEY_SECRET
JWT_SECRET=change-me-with-openssl-rand-hex-32
SESSION_SECRET=change-me-with-openssl-rand-hex-32
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
COOKIE_DOMAIN=
COOKIE_SECURE=true
FRONTEND_BASE_URL=https://example.com
OAUTH_REDIRECT_BASE=https://example.com/api/auth/oauth
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# 数据库（Docker Compose 默认主机名 manus-postgres；未设置 SQLALCHEMY_DATABASE_URI 时自动派生）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manus
POSTGRES_HOST=manus-postgres

# Redis（未设置密码时 REDIS_PASSWORD 留空）
REDIS_HOST=manus-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 腾讯云 COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_DOMAIN=

# Nginx 对外端口（仅 docker-compose）
NGINX_PORT=8088
NGINX_HTTPS_PORT=443

# 域名与 HTTPS（启用 HTTPS 前需自行准备证书，默认路径 /etc/letsencrypt/live/${MANUS_DOMAIN}/）
MANUS_DOMAIN=
HTTPS_ENABLED=false

# ---------- 按功能启用的密钥（可选） ----------

# 向量记忆：在 api/config.yaml 设置 memory.vector_enabled: true 后填写
EMBEDDING_API_KEY=

# 企业文档知识库连接器（可选）
CONFLUENCE_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Langfuse：在 api/config.yaml 设置 observability.langfuse_enabled: true 后填写
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Google/GitHub SSO（可选；保持空值则不启用对应登录入口）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- 高级可选项（通常无需修改） ----------

# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@manus-postgres:5432/manus
# APP_CONFIG_FILEPATH=config.yaml
# SQLALCHEMY_ECHO=false
# POSTGRES_POOL_SIZE=10
# POSTGRES_MAX_OVERFLOW=20
# POSTGRES_POOL_RECYCLE_SECONDS=1800
# COS_SCHEME=https
# USE_DB_APP_CONFIG=false

# Docker 构建期镜像源（覆盖 docker-compose build args 默认值）
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# PIP_TRUSTED_HOST=mirrors.aliyun.com
# UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# UV_VERSION=0.11.19
# NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
